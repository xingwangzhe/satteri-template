{
  "name": "satteri-<your-plugin>",
  "version": "0.1.0",
  "description": "<your description>",
  "type": "module",
  "license": "MIT",
  "author": "<your-name>",
  "homepage": "https://github.com/<your-name>/<your-repo>#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/<your-name>/<your-repo>"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --declarationDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint src test",
    "lint:fix": "oxlint --fix src test",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "satteri": ">=0.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "satteri": "^0.9.0",
    "typescript": "^7.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "astro",
    "astro-component",
    "satteri",
    "mdast",
    "markdown",
    "plugin"
  ]
}
